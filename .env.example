# DeepSeek API Configuration
# Get your API key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Public site URL (set to your Vercel domain or custom domain)
NEXT_PUBLIC_SITE_URL=https://chinese-name-website.vercel.app

# Google Analytics 4 (optional — set to enable analytics)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console verification (optional)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your_code_here

# Supabase (required for payments/credits)
# Create a free project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe (required for payments)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
